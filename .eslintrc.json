{
  "extends": [
    "eslint:recommended",
    "plugin:prettier/recommended"
  ],
  "env": {
    "node": true,
    "browser": true,
    "es2021": true,
    "jest": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "prettier/prettier": "error",
    "no-case-declarations": "off"
  },
  "globals": {
    "Utils": "readonly",
    "CrowdData": "readonly",
    "DashboardData": "readonly",
    "AIAssistant": "readonly",
    "StadiumMap": "readonly",
    "WSClient": "readonly",
    "Animations": "readonly"
  }
}
